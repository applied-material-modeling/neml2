# 3rd-party libraries
contrib/nlohmann_json
contrib/nlohmann_json-build
contrib/torch*

# CMake
*.cmake
!cmake/Modules/*
CMakeCache.txt
CMakeFiles
CMakeUserPresets.json
CMakeDoxyfile.in
compile_commands.json
detect_cuda*
Makefile
build
_deps
install
installed
hash
version

# Editor cache
*.swp
DartConfiguration.tcl
.cache
.vscode
*.log
.env
.clangd
.DS_Store

# Python
.venv
__pycache__
# Stubs are auto-generated by `neml2-stub` after install (see
# neml2/cli/stub.py); regenerated whenever any pybind11 extension
# changes, never tracked.
*.pyi
neml2.egg-info

# Tests
Testing
*.pt
!**/gold/*.pt
.pytest_cache

# Coverage
.coverage
.coverage.*
coverage.xml
htmlcov

# Objects and libraries
*.a
.libs
*.la
# `*.so*` would also match e.g. doc page filenames containing `.so`
# (`neml2.solvers.md`), so be explicit about ELF + versioned suffixes.
*.so
*.so.*
*.lo
*.lo.d
*.dylib

# Miscellaneous
*.pdf
*.gv
*.json
# Generated figures (benchmark plots, scratch screenshots) -- the only
# pngs that ever get tracked are committed UI/doc assets, so allow the
# `asset` / `assets` convention back in.
*.png
!**/asset/**/*.png
!**/assets/**/*.png
pyright-local.json
pyrightconfig.local.json

# Agents
.claude/settings.local.json
!.claude/settings.json
.claude/scheduled_tasks.json
.claude/scheduled_tasks.lock

# Files we want to make the user get
python/examples/kwn/*.tdb
.neml2_aoti/
.neml2_aoti_*/
# benchmark sweep transient AOTI cache
benchmark/results/_aoti_cache/
# but the per-folder metadata.json IS a committed artifact (overrides *.json above)
!benchmark/results/**/metadata.json
# and so is the default plot config that pins the canonical
# four-way comparison (v2/v3 x CPU/CUDA)
!benchmark/plot_throughput.json
.claude/
# codegraph index cache (local tooling)
.codegraph/

# llvm coverage raw profiles
*.profraw
